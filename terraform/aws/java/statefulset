apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: mongo
spec:
  serviceName: mongo
  replicas: 2
  selector:
    matchLabels:
      app: mongo
  template:
    metadata:
      labels:
        app: mongo
    spec:
      containers:
      - name: mongo
        image: 017341176608.dkr.ecr.us-east-1.amazonaws.com/mongo:latest
        ports:
        - containerPort: 27017
        command:
          - mongod
        args:
          - "--replSet"
          - "rs0"
          - "--bind_ip_all"

        volumeMounts:
        - name: mongo-data
          mountPath: /data/db

  volumeClaimTemplates:
  - metadata:
      name: mongo-data
    spec:
      storageClassName: gp3-storage
      accessModes: ["ReadWriteOnce"]
      resources:
        requests:
          storage: 1Gi
